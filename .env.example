# Used by the Next.js app (browser-side via NEXT_PUBLIC_*).
# These are baked into the JS bundle on build. The anon key is public
# by design; RLS on the cars table is what actually enforces security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace.with.anon.key
