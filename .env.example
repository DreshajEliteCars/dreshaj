# =============================================================================
# Frontend (Next.js) — set these in Vercel → Project → Settings → Environment.
# =============================================================================

# Browser-side. Baked into the JS bundle on build. The anon key is public
# by design; RLS on the `cars` / `app_settings` tables enforces security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace.with.anon.key

# =============================================================================
# Server-only (Next.js API routes) — set these as secret in Vercel.
# Used by /api/cars/[id]/inspection (and accidents/condition) which proxy
# Encar requests + cache results in Supabase via the service role.
# =============================================================================

# Supabase service-role key. NEVER expose with NEXT_PUBLIC_ prefix.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...replace.with.service.role.key
