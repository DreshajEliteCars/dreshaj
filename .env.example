# =============================================================================
# Server-only (Next.js API routes) — set these in Vercel → Project → Settings.
# These are NEVER shipped to the browser. All data fetching goes through
# API proxy routes (/api/cars, /api/settings, /api/featured).
# =============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...replace.with.anon.key

# Supabase service-role key. Used by /api/cars/[id]/inspection to cache
# inspection data. NEVER expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace.with.service.role.key

# =============================================================================
# Browser-side — only needed for the admin dashboard (/login, /dashboard).
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace.with.anon.key
