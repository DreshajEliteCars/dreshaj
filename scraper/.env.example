# Used by scraper.js. The service_role key bypasses RLS and must NEVER
# be shipped to the browser. Only set this on the machine that runs the
# scraper (locally for testing, or in GitHub Actions secrets in CI).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...replace.with.service.role.key

# Optional tuning ------------------------------------------------------------
# Comma-separated make aliases. Overrides scraper/carlist.txt when set.
# SCRAPER_TARGETS=bmw,porsche

# How many listings to request per page (default 500).
# SCRAPER_PAGE_SIZE=500

# Cap per make. Useful for testing a small batch. Disables the deletion
# safeguard (so we don't wipe rows just because we limited the fetch).
# SCRAPER_MAX_LISTINGS_PER_MAKE=50

# Markup added on top of the converted KRW->EUR price.
# SCRAPER_PRICE_MARKUP_EUR=400

# Network behaviour
# SCRAPER_TIMEOUT_MS=15000
# SCRAPER_MAX_RETRIES=5

# Detail-endpoint concurrency. Default 5 is safe for most proxies; with a
# decent residential/static proxy pool you can push to 8-10.
# SCRAPER_DETAIL_CONCURRENCY=5

# Skip detail re-fetch for rows whose updated_at is younger than this.
# Default 6 hours. Set 0 to always re-enrich (slower).
# SCRAPER_SKIP_FRESH_HOURS=6

# Proxies — comma- or newline-separated. Same formats as proxy.txt.
# When unset (and no proxy.txt), uses a direct connection.
# SCRAPER_PROXIES=user:pass@host1:port,user:pass@host2:port
# SCRAPER_PROXY=user:pass@host:port
